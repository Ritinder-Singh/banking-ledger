{
  "title": "Banking Ledger",
  "uid": "banking-ledger",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "timezone": "browser",
  "tags": ["banking", "ledger"],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Transactions completed (per second)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 25, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "calcs": ["lastNotNull", "mean", "max"], "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (rate(transactions_completed_total[1m]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Transactions failed (per second, by reason)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 25, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "calcs": ["lastNotNull", "mean", "max"], "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (rate(transactions_failed_total[1m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Idempotent duplicates blocked (total)",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(idempotent_duplicates_blocked_total)"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP requests by status (per second)",
      "gridPos": { "x": 6, "y": 8, "w": 18, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request latency p95 (seconds)",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "calcs": ["lastNotNull", "max"], "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (uri, le) (rate(http_server_requests_seconds_bucket[1m])))",
          "legendFormat": "{{uri}}"
        }
      ]
    }
  ]
}
